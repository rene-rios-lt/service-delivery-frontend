@inherits LayoutComponentBase
@using ServiceDelivery.Client.Core.Interfaces
@using ServiceDelivery.Client.Core.ViewModels
@using ServiceDelivery.Client.UI.Shared.Components
@using ServiceDelivery.Client.UI.Theme
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject ShellViewModel Shell

<MudThemeProvider Theme="@AppTheme.Instance" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @if (IsLoginRoute)
    {
        <MudMainContent>
            @Body
        </MudMainContent>
    }
    else
    {
        <PersonaShell ViewModel="Shell" Body="@Body" ShellVersion="@_shellVersion" />
    }
</MudLayout>

@code {
    // Incremented after Shell.Load so PersonaShell receives a changed primitive parameter and Blazor
    // re-renders the child. Without this, the unchanged Shell reference makes Blazor skip the child
    // render and PersonaMenu never re-evaluates `@if (ViewModel.Menu is not null)` post-login (BUG-025).
    private int _shellVersion = 0;

    private bool IsLoginRoute =>
        Navigation.ToBaseRelativePath(Navigation.Uri)
            .TrimStart('/')
            .StartsWith("login", StringComparison.OrdinalIgnoreCase);

    // OnParametersSetAsync (not OnInitializedAsync) is required here: the Router calls it on every
    // navigation by updating the Body parameter, so it fires when the user transitions from /login
    // to /dispatcher. OnInitializedAsync only runs once — on the login page — so Shell.Load was
    // never reached in the normal login flow.
    protected override async Task OnParametersSetAsync()
    {
        if (IsLoginRoute || Shell.Menu is not null)
        {
            return;
        }

        try
        {
            var profile = await AuthService.GetCurrentUserAsync();
            Shell.Load(profile);
            _shellVersion++;
        }
        catch
        {
            // No valid session yet — e.g. the transient root "/" route before the redirect to
            // /login resolves, or an expired token. Surfacing this would flash Blazor's "unhandled
            // error" UI; instead let the app's redirect-to-login flow (Home.razor / the session
            // expiry handler) route the user. (BUG-029 startup error flash.)
        }
    }
}
