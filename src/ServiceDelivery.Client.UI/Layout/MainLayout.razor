@inherits LayoutComponentBase
@using ServiceDelivery.Client.Core.Interfaces
@using ServiceDelivery.Client.Core.ViewModels
@using ServiceDelivery.Client.UI.Shared.Components
@using ServiceDelivery.Client.UI.Theme
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject ShellViewModel Shell

<MudThemeProvider Theme="@AppTheme.Instance" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @if (IsLoginRoute)
    {
        <MudMainContent>
            @Body
        </MudMainContent>
    }
    else
    {
        <PersonaShell ViewModel="Shell" Body="@Body" ShellVersion="@_shellVersion" />
    }
</MudLayout>

@code {
    // Incremented after Shell.Load so PersonaShell receives a changed primitive parameter and Blazor
    // re-renders the child. Without this, the unchanged Shell reference makes Blazor skip the child
    // render and PersonaMenu never re-evaluates `@if (ViewModel.Menu is not null)` post-login (BUG-025).
    private int _shellVersion = 0;

    private bool IsLoginRoute =>
        Navigation.ToBaseRelativePath(Navigation.Uri)
            .TrimStart('/')
            .StartsWith("login", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        if (!IsLoginRoute)
        {
            var profile = await AuthService.GetCurrentUserAsync();
            Shell.Load(profile);
            _shellVersion++;
        }
    }
}
