@using Microsoft.AspNetCore.Components
@using MudBlazor
@using ServiceDelivery.Client.Core.ViewModels

@* App-shell chrome for authenticated routes: a shared app bar (title + persona context + a menu
   affordance) above the page body, with the platform-adaptive PersonaMenu attached. The shell only
   renders chrome — it builds no menu data and calls no auth primitives directly; it binds to
   ShellViewModel. *@

<div data-testid="persona-shell" class="sd-shell">
    <MudAppBar Elevation="2" Class="sd-appbar" Fixed="false">
        <div class="sd-appbar__logo">🚐</div>
        <div>
            <div data-testid="appbar-title" class="sd-appbar__title">@ViewModel.Title</div>
            <div data-testid="appbar-context" class="sd-appbar__sub">@ContextSubtitle</div>
        </div>
        <MudSpacer />
        <div class="sd-appbar__controls">
            @if (ViewModel.IsMenuAffordanceVisible)
            {
                <MudIconButton data-testid="appbar-menu-affordance"
                               id="appbar-menu-affordance"
                               Icon="@MenuIcon"
                               Color="Color.Inherit"
                               OnClick="ViewModel.ToggleMenu"
                               Class="sd-appbar__action" />
            }
            @if (ViewModel.Menu is not null)
            {
                <MudAvatar data-testid="appbar-avatar" Class="sd-avatar">@Initials</MudAvatar>
            }
        </div>
    </MudAppBar>

    <PersonaMenu ViewModel="ViewModel" />

    <main class="sd-shell__body">
        @Body
    </main>
</div>

@code {
    [Parameter, EditorRequired]
    public ShellViewModel ViewModel { get; set; } = default!;

    [Parameter]
    public RenderFragment? Body { get; set; }

    // Carries no rendered data. Its sole purpose is to give Blazor's parameter differ a changed
    // primitive value (int 0 -> 1) after MainLayout calls Shell.Load(profile), so the child render
    // cycle runs and PersonaMenu's `@if (ViewModel.Menu is not null)` is re-evaluated post-login.
    // Without it the unchanged ShellViewModel reference makes Blazor skip the child re-render (BUG-025).
    [Parameter]
    public int ShellVersion { get; set; }

    private string ContextSubtitle => ViewModel.Subtitle ?? ViewModel.Menu?.VehicleContext ?? ViewModel.Menu?.ContextLine ?? string.Empty;

    private string MenuIcon => ViewModel.IsMenuOpen ? Icons.Material.Filled.Close : Icons.Material.Filled.Menu;

    // Same initials derivation as PersonaMenu.razor — reproduced here (per BUG-033 review) rather
    // than extracted, keeping the small two-letter avatar label consistent across the app bar and
    // the menu surface without coupling the two components.
    private string Initials =>
        string.Concat((ViewModel.Menu?.Title ?? string.Empty)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => part[0]))
            .ToUpperInvariant();
}
