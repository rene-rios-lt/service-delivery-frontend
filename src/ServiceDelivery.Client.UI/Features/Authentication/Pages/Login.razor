@page "/login"
@using ServiceDelivery.Client.Core.ViewModels
@inject LoginViewModel ViewModel

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
    <MudCard data-testid="login-card" Class="pa-6" Style="width: 100%; max-width: 380px;">
        <MudCardContent>
            <div class="d-flex flex-column align-center mb-4">
                <MudText Typo="Typo.h5" Align="Align.Center">Service Delivery</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center">Sign in to continue</MudText>
            </div>

            <MudTextField data-testid="email-input"
                          @bind-Value="ViewModel.Email"
                          Label="Username"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          Disabled="ViewModel.IsBusy" />

            <MudTextField data-testid="password-input"
                          @bind-Value="ViewModel.Password"
                          Label="Password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Class="mb-3"
                          Disabled="ViewModel.IsBusy" />

            @if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
            {
                <MudAlert data-testid="login-error" Severity="Severity.Error" Class="mb-3">
                    @ViewModel.ErrorMessage
                </MudAlert>
            }

            <MudButton data-testid="sign-in-button"
                       OnClick="SignInAsync"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="ViewModel.IsBusy">
                Sign in
            </MudButton>

            <MudText Typo="Typo.caption" Align="Align.Center" Class="d-block mt-4">
                You'll be routed to your view automatically by role.
            </MudText>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private async Task SignInAsync()
    {
        await ViewModel.LoginAsync();
    }
}
