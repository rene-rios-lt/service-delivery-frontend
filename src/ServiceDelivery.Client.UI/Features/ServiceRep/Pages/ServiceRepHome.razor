@page "/rep"
@using Microsoft.AspNetCore.Components
@using ServiceDelivery.Client.UI.Features.Authentication.Services
@inject NavigationManager Navigation

@* The /rep route is the legacy ServiceRep placeholder. The real resting screen is the idle /
   waiting-for-offers view at /rep/idle (FE-020), so any landing on /rep redirects there to keep a
   single canonical idle route. Take-over success and post-job transitions navigate to /rep/idle
   directly via PersonaRouteMap.ServiceRepIdle. *@

@code {
    protected override void OnInitialized()
    {
        Navigation.NavigateTo(PersonaRouteMap.ServiceRepIdle, replace: true);
    }
}
