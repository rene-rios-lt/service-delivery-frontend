@page "/rep/job"
@using System.Globalization
@using System.Threading
@using MudBlazor
@using ServiceDelivery.Client.Core.Models
@using ServiceDelivery.Client.Core.ViewModels
@using ServiceDelivery.Client.UI.Features.Maps.Components
@implements IDisposable
@inject ActiveJobViewModel ViewModel
@inject ShellViewModel Shell
@inject ISnackbar Snackbar

<div class="sd-active-job" data-testid="active-job">
    @* App bar, hamburger menu, and avatar come from the shared PersonaShell (FE-021) that wraps every
       authenticated route — like every other rep page. This screen renders only the map + bottom sheet
       into the shell body; the En Route / Within 15 mi / On Site status is carried by the state chip. *@
    <div class="sd-map" data-testid="active-job-map">
        <div class="sd-eta" data-testid="eta-card" id="eta-card">
            <span class="sd-eta__num" data-testid="eta-minutes">@ViewModel.EtaMinutes min</span>
            <span class="sd-eta__lbl" data-testid="eta-distance">ETA · @ViewModel.DistanceMiles.ToString("F1", CultureInfo.InvariantCulture) MI</span>
        </div>

        @if (ViewModel.IsOnSite)
        {
            <div class="sd-popover" data-testid="at-location-pill">
                <span>📍</span> At requester location
            </div>
        }

        <div class="sd-chip @StateChipClass" data-testid="state-chip">
            <span class="sd-chip__dot"></span>@StateLabel
        </div>

        @* FE-026: the real Google map (FE-024 GoogleMap component) replaces the former CSS/SVG placeholder.
           The rep marker, requester pin, and route polyline are now real map overlays placed via the
           imperative interop API in UpdateMapOverlaysAsync — not DOM elements in this markup. The map
           centres on the requester at a city-level zoom initially; FitBoundsAsync then frames both points. *@
        <GoogleMap @ref="_map" Lat="@ViewModel.RequesterLat" Lng="@ViewModel.RequesterLng" Zoom="13"
                   OnMapReady="UpdateMapOverlaysAsync" />
    </div>

    <div class="sd-sheet" data-testid="bottom-sheet">
        <div class="sd-sheet__grip"></div>
        <div class="sd-reqcard__row">
            <div class="sd-listitem__icon">🔧</div>
            <div class="sd-card__title" data-testid="requester-name">@ViewModel.RequesterName</div>
            @if (!string.IsNullOrWhiteSpace(ViewModel.Tier))
            {
                <span class="sd-badge @TierBadgeClass" data-testid="tier-badge">
                    <span class="sd-badge__icon">⭐</span>@ViewModel.Tier
                </span>
            }
        </div>
        <div class="sd-reqcard__dtc" data-testid="dtc-title">@ViewModel.DtcTitle</div>
        @if (ViewModel.IsOnSite)
        {
            <button type="button" class="sd-btn sd-btn--primary sd-btn--block sd-btn--lg"
                    data-testid="complete-button" id="complete-button"
                    @onclick="OnCompleteClicked">
                Mark Complete
            </button>
        }
        else
        {
            <button type="button" class="sd-btn sd-btn--primary sd-btn--block sd-btn--lg"
                    data-testid="arrived-button" id="arrived-button" disabled="@(!ViewModel.IsArrivedEnabled)"
                    @onclick="OnArrivedClicked">
                @ArrivedButtonLabel
            </button>
        }
    </div>
</div>

@code {
    private static readonly TimeSpan PollInterval = TimeSpan.FromSeconds(3);

    private Timer? _pollTimer;

    // Captures the embedded GoogleMap (FE-024) so the page can drive its imperative overlay API
    // (markers / polyline / pan / zoom / fitBounds) from OnAfterRenderAsync and each poll/state change.
    private GoogleMap? _map;

    // Maps the request tier (Gold/Silver/Bronze) to its design-system badge modifier generically —
    // no per-tier hardcoding, so a new tier needs only its design-system class, not a code branch.
    private string TierBadgeClass => $"sd-badge--{ViewModel.Tier.ToLowerInvariant()}";

    private string StateLabel =>
        ViewModel.IsOnSite ? "On Site"
        : ViewModel.IsArrivedEnabled ? "Within 15 mi"
        : "En Route";

    private string StateChipClass =>
        ViewModel.IsOnSite ? "sd-chip--onsite"
        : ViewModel.IsArrivedEnabled ? "sd-chip--within15"
        : "sd-chip--enroute";

    private string ArrivedButtonLabel =>
        ViewModel.IsArrivedEnabled ? "I've Arrived" : "I've Arrived · enables within 15 mi";

    // The en-route subtitle shown while the rep is navigating to the requester (BUG-039 / mockup).
    private const string EnRouteSubtitle = "Navigating to requester";

    // The state-appropriate subtitle once the rep has arrived on-site (BUG-039).
    private const string OnSiteSubtitle = "At requester location";

    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateChanged += OnViewModelStateChanged;
        Shell.SetTitle("Active Job");
        Shell.SetSubtitle(EnRouteSubtitle);
        // FE-014/AC-2: a job is InProgress while this screen owns the view, so the rep must not be able
        // to release the vehicle mid-job. This is the production caller that gates the "Release vehicle"
        // nav item off; Dispose re-enables it when the rep leaves (job complete / idle).
        Shell.SetReleaseEnabled(false);
        await ViewModel.LoadAsync();
        ApplyShellSubtitleForState();
        await ViewModel.StartAsync();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        // Poll the rep's simulator-driven position every ~3 seconds (AC-1). The timer fires on a pool
        // thread; each tick marshals back onto the renderer via InvokeAsync. Tests call PollOnceAsync
        // directly so no real-time delay is needed. The initial map overlays (rep marker, requester pin,
        // route polyline) are placed from the GoogleMap's OnMapReady callback (FE-026) — not here — because
        // this OnAfterRender runs before the embedded map has imported its JS module.
        if (firstRender)
        {
            _pollTimer = new Timer(_ => _ = InvokeAsync(PollOnceAsync), null, PollInterval, PollInterval);
        }
    }

    // Polls the rep's live position; PollPositionAsync raises StateChanged, which refreshes the map
    // overlays (and re-renders) via OnViewModelStateChanged — so no explicit overlay call is needed here.
    public Task PollOnceAsync() => ViewModel.PollPositionAsync();

    // Drives the real Google map overlays (FE-026) from the current ViewModel state. The rep marker tracks
    // the rep's live position and recolours per state. While the rep is still travelling (not on-site) the
    // requester pin is shown so both ends of the trip are visible.
    private async Task UpdateMapOverlaysAsync()
    {
        if (_map is null)
        {
            return;
        }

        await _map.AddOrUpdateMarkerAsync(
            RepMarkerId, ViewModel.RepLat, ViewModel.RepLng, RepStateColour.ForState(MapRepState), RepMarkerTestId);

        if (!ViewModel.IsOnSite)
        {
            await _map.AddOrUpdateMarkerAsync(
                RequesterMarkerId, ViewModel.RequesterLat, ViewModel.RequesterLng, RequesterPinColour, RequesterMarkerTestId);
            await _map.AddOrUpdatePolylineAsync(RouteId, RoutePoints(), RouteTestId);
            // En route / within 15 mi: frame both ends of the trip so the rep and requester stay visible
            // regardless of distance (fitBounds auto-fits the zoom).
            await _map.FitBoundsAsync(RoutePoints());
        }
        else
        {
            // On-site: the trip is over — drop the route polyline and the requester pin so only the
            // single combined rep+requester marker remains over the work site (mockup: rep-on-site), then
            // recentre on the rep at a street-level zoom for the close-up work.
            await _map.RemovePolylineAsync(RouteId);
            await _map.RemoveMarkerAsync(RequesterMarkerId);
            await _map.PanToAsync(ViewModel.RepLat, ViewModel.RepLng);
            await _map.SetZoomAsync(OnSiteZoom);
        }
    }

    // Street-level zoom used once the rep is on-site (the requester pin is gone; a close-up view is most
    // useful for the work). En route / within 15 mi rely on fitBounds, which manages zoom automatically.
    private const int OnSiteZoom = 15;

    // The rep→requester trip points for the route polyline (ordered rep first, requester second).
    private GpsPoint[] RoutePoints() =>
    [
        new GpsPoint(ViewModel.RepLat, ViewModel.RepLng),
        new GpsPoint(ViewModel.RequesterLat, ViewModel.RequesterLng),
    ];

    private const string RepMarkerId = "rep";
    private const string RepMarkerTestId = "rep-marker";
    private const string RequesterMarkerId = "requester";
    private const string RequesterMarkerTestId = "requester-pin";
    private const string RouteId = "route";
    private const string RouteTestId = "route-line";

    // The requester pin's neutral-dark colour (design-system sd-pin-dest token) — the destination dot in
    // the en-route mockup, distinct from the state-coloured rep marker.
    private const string RequesterPinColour = "#2B2F3A";

    // The rep state used to colour the rep marker, mirroring the StateLabel/StateChipClass computed
    // properties so the marker colour, state chip, and label all stay in lock-step (OnSite → red,
    // Within15Miles → yellow, otherwise EnRoute → blue).
    private string MapRepState =>
        ViewModel.IsOnSite ? "OnSite"
        : ViewModel.IsArrivedEnabled ? "Within15Miles"
        : "EnRoute";

    private Task OnArrivedClicked() => ViewModel.ArriveAsync();

    // The confirmation toast (AC-3) is a presentation concern owned by the page, not the ViewModel.
    // It is shown before CompleteAsync navigates away so the rep sees the confirmation as the screen
    // transitions back to the idle waiting view.
    private const string CompleteToastMessage = "Job marked complete";

    private async Task OnCompleteClicked()
    {
        Snackbar.Add(CompleteToastMessage, Severity.Success);
        await ViewModel.CompleteAsync();
    }

    private void OnViewModelStateChanged()
    {
        ApplyShellSubtitleForState();
        // A state change (arrival, redirect, poll) can move/recolour markers, redraw or drop the route
        // polyline, and reframe the map — so refresh the overlays alongside the Razor re-render (FE-026).
        InvokeAsync(async () =>
        {
            await UpdateMapOverlaysAsync();
            StateHasChanged();
        });
    }

    // Keeps the app-bar subtitle state-appropriate: "At requester location" once the rep is on-site,
    // otherwise the en-route "Navigating to requester".
    private void ApplyShellSubtitleForState() =>
        Shell.SetSubtitle(ViewModel.IsOnSite ? OnSiteSubtitle : EnRouteSubtitle);

    public void Dispose()
    {
        _pollTimer?.Dispose();
        ViewModel.StateChanged -= OnViewModelStateChanged;
        Shell.SetTitle(null);
        Shell.SetSubtitle(null);
        // The job is no longer InProgress once this screen leaves — release becomes available again
        // (FE-014/AC-2). The screen owns restoring the gate, mirroring how it restores title/subtitle.
        Shell.SetReleaseEnabled(true);
    }
}
