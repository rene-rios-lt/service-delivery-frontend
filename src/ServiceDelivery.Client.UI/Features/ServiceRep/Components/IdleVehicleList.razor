@using Microsoft.AspNetCore.Components
@using MudBlazor
@using ServiceDelivery.Client.Core.Models

@* Renders the idle-vehicle list inside a bordered card (mockup: rep-takeover__mobile-390x844).
   Each row shows a truck icon, the registration as the title, an "idle" subtitle, and the
   vehicle's equipment as chips (collapsed to the first two plus an overflow count). Display only.
   The backend GET /vehicles/available contract returns only registration + equipment, so model
   and loop are not shown. *@

<div data-testid="idle-vehicle-list" id="idle-vehicle-list" class="sd-card">
    @foreach (var vehicle in Vehicles)
    {
        <div data-testid="idle-vehicle-row"
             id="idle-vehicle-row"
             class="sd-listitem @(IsSelected(vehicle) ? "idle-vehicle-row--selected" : null)"
             @onclick="() => OnSelect.InvokeAsync(vehicle.VehicleId)">
            <div class="sd-listitem__icon">🚐</div>
            <div>
                <div class="sd-listitem__title">@vehicle.Registration</div>
                <div class="sd-listitem__sub">idle</div>
                <div class="sd-equip">
                    @foreach (var equipment in VisibleEquipment(vehicle))
                    {
                        <span data-testid="equipment-chip">@FriendlyLabel(equipment)</span>
                    }
                    @if (OverflowCount(vehicle) > 0)
                    {
                        <span data-testid="equipment-overflow">+@OverflowCount(vehicle)</span>
                    }
                </div>
            </div>
            <div class="sd-listitem__spacer"></div>
            @if (IsSelected(vehicle))
            {
                <MudIcon data-testid="selected-check"
                         Icon="@Icons.Material.Filled.Check"
                         Color="Color.Primary" />
            }
        </div>
    }
</div>

@code {
    private const int MaxVisibleEquipment = 2;

    // Maps the raw EquipmentType enum names the backend returns (AvailableVehicleDto serialises
    // EquipmentType.ToString() — verified against ServiceDelivery.Domain.Enums.EquipmentType) to the
    // short, human-friendly chip labels shown in the mockup. Unknown keys fall through to the raw
    // string so a new enum value never renders blank. Display-only concern → lives in the component.
    private static readonly IReadOnlyDictionary<string, string> EquipmentLabels =
        new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["HydraulicTool"]            = "Hydraulics",
            ["ElectricalDiagnosticKit"] = "Diagnostics",
            ["TransmissionKit"]         = "Transmission",
            ["BrakingSystemKit"]        = "Braking",
            ["CoolingSystemKit"]        = "Coolant",
            ["FuelSystemKit"]           = "Fuel",
            ["ExhaustSystemKit"]        = "Exhaust",
            ["SuspensionKit"]           = "Suspension",
            ["SteeringKit"]             = "Steering",
            ["PowertrainKit"]           = "Powertrain",
        };

    private static string FriendlyLabel(string raw) =>
        EquipmentLabels.TryGetValue(raw, out var label) ? label : raw;

    [Parameter, EditorRequired]
    public IReadOnlyList<IdleVehicle> Vehicles { get; set; } = [];

    [Parameter]
    public Guid? SelectedVehicleId { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSelect { get; set; }

    private bool IsSelected(IdleVehicle vehicle) => SelectedVehicleId == vehicle.VehicleId;

    private static IEnumerable<string> VisibleEquipment(IdleVehicle vehicle) =>
        vehicle.EquipmentTypes.Take(MaxVisibleEquipment);

    private static int OverflowCount(IdleVehicle vehicle) =>
        Math.Max(0, vehicle.EquipmentTypes.Count - MaxVisibleEquipment);
}
