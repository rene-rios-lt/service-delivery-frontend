@using Microsoft.AspNetCore.Components
@using MudBlazor
@using ServiceDelivery.Client.Core.Models

@* Renders the idle-vehicle list inside a bordered card (mockup: rep-takeover__mobile-390x844).
   Each row shows a truck icon, the title ("<registration> · <model>", matching the mockup), an
   "idle" subtitle, and the vehicle's equipment as chips (collapsed to the first two plus an
   overflow count). Display only. The "· <model>" suffix is guarded so a vehicle with no model
   renders the registration alone — the same empty-guard pattern used by the idle card in
   RepIdle.razor (BUG-035). *@

<div data-testid="idle-vehicle-list" id="idle-vehicle-list" class="sd-card">
    @foreach (var vehicle in Vehicles)
    {
        <div data-testid="idle-vehicle-row"
             id="idle-vehicle-row"
             class="sd-listitem @(IsSelected(vehicle) ? "idle-vehicle-row--selected" : null)"
             @onclick="() => OnSelect.InvokeAsync(vehicle.VehicleId)">
            <div class="sd-listitem__icon">🚐</div>
            <div>
                <div class="sd-listitem__title">@vehicle.Registration@(string.IsNullOrEmpty(vehicle.Model) ? "" : $" · {vehicle.Model}")</div>
                <div class="sd-listitem__sub">idle</div>
                <div class="sd-equip">
                    @foreach (var equipment in VisibleEquipment(vehicle))
                    {
                        <span data-testid="equipment-chip">@EquipmentLabels.FriendlyLabel(equipment)</span>
                    }
                    @if (OverflowCount(vehicle) > 0)
                    {
                        <span data-testid="equipment-overflow">+@OverflowCount(vehicle)</span>
                    }
                </div>
            </div>
            <div class="sd-listitem__spacer"></div>
            @if (IsSelected(vehicle))
            {
                <MudIcon data-testid="selected-check"
                         Icon="@Icons.Material.Filled.Check"
                         Color="Color.Primary" />
            }
        </div>
    }
</div>

@code {
    private const int MaxVisibleEquipment = 2;

    // Friendly equipment labels are mapped through the shared EquipmentLabels helper in Core so the
    // take-over list and the idle card (RepIdle) render identical text from a single source (BUG-034).

    [Parameter, EditorRequired]
    public IReadOnlyList<IdleVehicle> Vehicles { get; set; } = [];

    [Parameter]
    public Guid? SelectedVehicleId { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSelect { get; set; }

    private bool IsSelected(IdleVehicle vehicle) => SelectedVehicleId == vehicle.VehicleId;

    private static IEnumerable<string> VisibleEquipment(IdleVehicle vehicle) =>
        vehicle.EquipmentTypes.Take(MaxVisibleEquipment);

    private static int OverflowCount(IdleVehicle vehicle) =>
        Math.Max(0, vehicle.EquipmentTypes.Count - MaxVisibleEquipment);
}
