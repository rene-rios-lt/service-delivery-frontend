@page "/requester/tracking"
@using MudBlazor

@* Requester rep-tracking view — forward-reference stub (FE-016). NavigateToRequesterTracking (AC-3)
   lands here after a RepAssigned event arrives on RequesterHub. FE-017 replaces this body with the real
   Uber-like rep-tracking implementation; for now it is a spinner + status line so the post-assignment
   navigation target is valid and meaningful (the same stub pattern FE-015 used for /requester/pending). *@

<div class="d-flex flex-column align-center justify-center pa-8" data-testid="requester-tracking">
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    <MudText Typo="Typo.h6" Align="Align.Center" Class="mt-4">Your technician is on the way…</MudText>
</div>
